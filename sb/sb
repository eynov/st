#!/bin/bash
# ==============================================================================
# sing-box 模块化容器多实例微服务集群管理面板
# 快捷命令: sb
# ==============================================================================
set -e

if [ "$EUID" -ne 0 ]; then
    echo "❌ 错误：请以 root 权限运行此面板！"
    exit 1
fi

# 🔥 动态获取脚本真实物理路径（自动追踪软链接）
BASE_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

# 引入核心模块
source "$BASE_DIR/core/common.sh"
source "$BASE_DIR/core/state.sh"
source "$BASE_DIR/core/install.sh"
source "$BASE_DIR/core/service.sh"
source "$BASE_DIR/core/runtime.sh"

# 🔥 动态加载所有协议插件（协议自注册，主脚本零感知）
for f in "$BASE_DIR/protocols"/*.sh; do
    [ -f "$f" ] && source "$f"
done

# 初始化运行时资产目录
mkdir -p "$INST_DIR" "$CERT_DIR"
state_init
state_sync_from_instances

# ==============================================================================
# 新增实例
# 升级点：菜单动态从 PROTO_MENU 生成，去除硬编码 case
# ==============================================================================
add_instance() {
    check_and_install_core

    echo "======================================"
    echo " 🚀 选择服务挂载协议"

    # 动态生成编号菜单（按 PROTO_KEYS 注册顺序，顺序固定）
    local i=1
    declare -A PROTO_INDEX
    for key in "${PROTO_KEYS[@]}"; do
        echo " $i) ${PROTO_MENU[$key]}"
        PROTO_INDEX[$i]="$key"
        ((i++))
    done
    echo "======================================"
    read -p ">> " proto_choice

    local selected_key="${PROTO_INDEX[$proto_choice]}"
    if [ -z "$selected_key" ]; then
        err "非法输入"; return
    fi

    read -p "输入挂载端口: " port
    if [ -z "$port" ]; then
        err "端口不能为空"; return
    fi
    if port_used "$port"; then
        err "端口 [${port}] 已被内核套接字占用！"; return
    fi

    mkdir -p "${INST_DIR}/${port}"

    # 🔥 动态调用协议 build 函数，无需 case
    local build_fn="${PROTO_BUILD[$selected_key]}"
    if ! "$build_fn" "$port"; then
        err "协议构建失败，正在回滚..."
        rm -rf "${INST_DIR}/${port}"
        return
    fi

    # 配置合规性校验
    if ! $SB_BIN check -c "${INST_DIR}/${port}/config.json" 2>/dev/null; then
        err "内核检测到 JSON 配置存在语法错误，正在回滚..."
        rm -rf "${INST_DIR}/${port}"
        state_del "$port"
        return
    fi

    gen_service "$port"
    systemctl daemon-reload
    systemctl enable "sb-${port}" >/dev/null 2>&1
    systemctl restart "sb-${port}"

    sleep 2
    if systemctl is-active --quiet "sb-${port}"; then
        ok "实例 [${port}] 部署挂载上线成功！"
        local dynamic_uri surge_format
        dynamic_uri=$(generate_dynamic_uri "${INST_DIR}/${port}" "uri")
        surge_format=$(generate_dynamic_uri "${INST_DIR}/${port}" "surge")

        echo -e "\n📋 【标准通用链接】:\n\033[36m${dynamic_uri}\033[0m"
        echo -e "\n📋 【Surge 托管配置格式】:\n\033[32m${surge_format}\033[0m"
        show_qr "$dynamic_uri"
    else
        err "内核进程启动失败，捕获 Systemd 错误日志..."
        journalctl -u "sb-${port}" -n 10 --no-pager
        # 启动失败：软停用，保留数据供排查
        state_disable "$port"
    fi
}

# ==============================================================================
# 删除实例
# 升级点：同步调用 state_del 清除 State Store 记录，集成 Runtime 强一致性清理层
# ==============================================================================
delete_instance() {
    read -p "请输入欲卸载删除的端口实例: " port
    if [ -z "$(state_get "$port")" ] && [ ! -d "${INST_DIR}/${port}" ]; then
        err "指定的实例在数据库中不存在"
        return
    fi

    read -p "⚠️  警告：彻底清除端口 [${port}] 的所有配置与资产吗？输入 YES 确认: " confirm
    if [ "$confirm" != "YES" ]; then
        echo "安全退出，未做改动"; return
    fi

    systemctl stop "sb-${port}" 2>/dev/null || true
    systemctl disable "sb-${port}" 2>/dev/null || true
    rm -f "/etc/systemd/system/sb-${port}.service"

    # =========================================
    # 🧨 强一致性修复：Runtime 强制清理层
    # =========================================

    # 1️⃣ 杀 systemd 未完全回收的残留进程
    pkill -9 -f "sing-box.*${port}" 2>/dev/null || true
    pkill -9 -f "ss-server.*${port}" 2>/dev/null || true
    pkill -9 sing-box 2>/dev/null || true

    sleep 1

    # 2️⃣ 二次确认是否仍有监听（防 ghost port）
    if ss -tulnp | grep -q ":${port}"; then
        warn "⚠️ 端口仍在监听（可能存在 systemd socket / orphan process）"
        ss -tulnp | grep ":${port}" || true

        # 再次强杀所有相关进程
        fuser -k "${port}/tcp" 2>/dev/null || true
        fuser -k "${port}/udp" 2>/dev/null || true
    fi

    rm -rf "${INST_DIR}/${port}"
    rm -f "${CERT_DIR}/cert_${port}.crt" "${CERT_DIR}/private_${port}.key"

    # 同步清除 State Store
    state_del "$port"

    systemctl daemon-reload
    systemctl reset-failed "sb-${port}" 2>/dev/null || true
    ok "端口 [${port}] 联动底层安全抹除完毕。"
}

# ==============================================================================
# 查看实例详情
# 升级点：从 state_list 读取端口列表，不再遍历目录
# ==============================================================================
show_instance_detail() {
    echo "=========================================================="
    echo " 🔍 全局实例状态拓扑树"
    echo "=========================================================="

    local ports
    mapfile -t ports < <(state_list)

    if [ "${#ports[@]}" -eq 0 ]; then
        warn "当前 State Store 中无任何实例记录。"
        return
    fi

    printf "%-10s | %-10s | %-10s | %-22s | %-14s\n" \
        "监听端口" "协议" "状态标记" "部署时间" "Systemd"
    echo "----------------------------------------------------------"

    for p in "${ports[@]}"; do
        local proto created enabled sys_status enabled_label
        proto=$(state_get_field "$p" "protocol")
        created=$(state_get_field "$p" "created_at")
        enabled=$(state_get_field "$p" "enabled")

        [ "$enabled" == "true" ] && enabled_label="✅ on" || enabled_label="⛔ off"

        if systemctl is-active --quiet "sb-${p}" 2>/dev/null; then
            sys_status="🟢 Running"
        else
            sys_status="🔴 Stopped"
        fi

        printf "%-10s | %-10s | %-10s | %-22s | %-14s\n" \
            "$p" "$proto" "$enabled_label" "$created" "$sys_status"
    done
    echo "=========================================================="

    read -p "请输入要查看凭证详情的端口 (回车返回): " sel_port
    [ -z "$sel_port" ] && return

    local target_dir="${INST_DIR}/${sel_port}"
    if [ -z "$(state_get "$sel_port")" ]; then
        err "该端口在 State Store 中不存在！"
        return
    fi

    echo -e "\n=================================================="
    echo "     sing-box 端口 [${sel_port}] 动态运行期资产明细"
    echo "=================================================="

    local active_uri surge_format
    active_uri=$(generate_dynamic_uri "$target_dir" "uri")
    surge_format=$(generate_dynamic_uri "$target_dir" "surge")

    echo -e "📌 协议:       $(state_get_field "$sel_port" "protocol")"
    echo -e "📌 加密方式:   $(state_get_field "$sel_port" "method" || echo "无")"
    echo -e "📌 密钥:       $(state_get_field "$sel_port" "password")"

    local proto
    proto=$(state_get_field "$sel_port" "protocol")
    if [ "$proto" == "HY2" ]; then
        echo -e "📌 SNI:        $(state_get_field "$sel_port" "sni")"
    fi

    echo -e "📌 URI:        \033[36m${active_uri}\033[0m"
    echo -e "📌 Surge:      \033[32m${surge_format}\033[0m"

    show_qr "$active_uri"

    echo -e "\n⚙️  端口监听状态:"
    ss -tulnp | grep -E ":${sel_port}\s" || warn "内核当前未对该端口开放监听！"
    echo "=================================================="
}

# ==============================================================================
# 主菜单循环
# ==============================================================================
while true; do
    echo ""
    echo "========================================="
    echo "   sing-box 容器化多实例智能管理面板 v4"
    echo "========================================="
    echo " 1. 新增 端口协议实例"
    echo " 2. 删除 指定端口实例"
    echo " 3. 查看 实例全局状态及凭证详情"
    echo " 4. 重启 全部运行中的端口实例"
    echo " 0. 退出管理面板"
    echo "========================================="
    read -p "请输入调度指令 >> " opt

    case $opt in
        1) add_instance ;;
        2) delete_instance ;;
        3) show_instance_detail ;;
        4) restart_all ;;
        0) echo "服务安全退出。"; exit 0 ;;
        *) echo "❌ 非法输入" ;;
    esac
done
