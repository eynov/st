#!/bin/bash
# ==============================================================================
# sb - sing-box 管理工具
# ==============================================================================

REAL_SOURCE="$(readlink -f "${BASH_SOURCE[0]}")"
BASE_DIR="$(cd "$(dirname "${REAL_SOURCE}")" && pwd)"

source "$BASE_DIR/core/common.sh"
source "$BASE_DIR/core/state.sh"
source "$BASE_DIR/core/registry.sh"
source "$BASE_DIR/core/runtime.sh"
source "$BASE_DIR/core/service.sh"
source "$BASE_DIR/core/install.sh"
load_protocols

[[ "$EUID" -ne 0 ]] && { err "请以 root 权限运行"; exit 1; }

ensure_dirs

# ------------------------------------------------------------------------------
# 内部：修改 state 后自动 compile + reload
# ------------------------------------------------------------------------------
_commit() {
    compile_all && service_reload
}

# ------------------------------------------------------------------------------
# 内部：解析实例参数 → id，失败则 exit
# 用法: _resolve <arg1> [arg2]
# ------------------------------------------------------------------------------
_resolve() {
    local id
    id=$(resolve_id "$@") || exit 1
    echo "$id"
}

# ------------------------------------------------------------------------------
# 交互菜单：无参数运行 sb 时进入
# ------------------------------------------------------------------------------
interactive_menu() {
    while true; do
        echo ""
        echo "┌─────────────────────────────────┐"
        echo "│         sb 管理菜单             │"
        echo "├─────────────────────────────────┤"
        echo "│  1) 添加节点                    │"
        echo "│  2) 查看节点列表                │"
        echo "│  3) 编辑节点                    │"
        echo "│  4) 删除节点                    │"
        echo "│  5) 启用节点                    │"
        echo "│  6) 停用节点                    │"
        echo "│  7) 重启单个节点                │"
        echo "│  8) 查看节点详情 / 分享链接     │"
        echo "├─────────────────────────────────┤"
        echo "│  9) 服务管理（启动/停止/状态）  │"
        echo "│ 10) 查看订阅                    │"
        echo "│ 11) 安装 / 升级 sing-box        │"
        echo "├─────────────────────────────────┤"
        echo "│  0) 退出                        │"
        echo "└─────────────────────────────────┘"
        read -rp "请输入编号: " choice

        case "$choice" in
            1)
                "$0" add
                ;;
            2)
                "$0" list
                ;;
            3)
                read -rp "实例 id（如 is01）: " mid
                "$0" edit "$mid"
                ;;
            4)
                read -rp "实例 id（如 is01）: " mid
                "$0" remove "$mid"
                ;;
            5)
                read -rp "实例 id（如 is01）: " mid
                "$0" enable "$mid"
                ;;
            6)
                read -rp "实例 id（如 is01）: " mid
                "$0" disable "$mid"
                ;;
            7)
                read -rp "实例 id（如 is01）: " mid
                "$0" restart "$mid"
                ;;
            8)
                read -rp "实例 id（如 is01）: " mid
                "$0" info "$mid"
                ;;
            9)
                echo ""
                echo "  1) 启动   2) 停止   3) 状态   4) 日志"
                read -rp "请选择: " sc
                case "$sc" in
                    1) "$0" start  ;;
                    2) "$0" stop   ;;
                    3) "$0" status ;;
                    4) "$0" logs   ;;
                    *) warn "无效选择" ;;
                esac
                ;;
            10)
                "$0" sub
                ;;
            11)
                "$0" install
                ;;
            0)
                echo "已退出"
                exit 0
                ;;
            *)
                warn "无效选择"
                ;;
        esac

        echo ""
        read -rp "按回车键返回菜单..." _
    done
}

# ==============================================================================
# 命令路由
# ==============================================================================

# 无参数运行 → 进入交互菜单
if [ $# -eq 0 ]; then
    interactive_menu
    exit 0
fi

CMD="${1:-help}"
shift || true

case "$CMD" in

# ------------------------------------------------------------------------------
# sb install
# ------------------------------------------------------------------------------
install)
    check_and_install_core
    gen_service
    ;;

# ------------------------------------------------------------------------------
# sb add [proto] [port]
# ------------------------------------------------------------------------------
add)
    proto="${1:-}"
    port="${2:-}"

    # 选择协议
    if [ -z "$proto" ] || [ -z "${PROTO_BUILD[$proto]+x}" ]; then
        echo ""
        echo "可用协议："
        i=1
        for k in "${PROTO_KEYS[@]}"; do
            printf "  %d) %-10s %s\n" "$i" "$k" "${PROTO_MENU[$k]}"
            (( i++ ))
        done
        echo ""
        read -rp "输入编号或协议名: " choice
        if [[ "$choice" =~ ^[0-9]+$ ]]; then
            proto="${PROTO_KEYS[$((choice-1))]}"
        else
            proto="${choice^^}"
        fi
    else
        proto="${proto^^}"
    fi

    if [ -z "${PROTO_BUILD[$proto]+x}" ]; then
        err "未知协议: ${proto}"
        exit 1
    fi

    # 输入端口
    if [ -z "$port" ]; then
        read -rp "端口号: " port
    fi

    port_valid "$port" || { err "端口号非法: ${port}"; exit 1; }

    # 调用协议 build
    "${PROTO_BUILD[$proto]}" "$port" || exit 1

    _commit
    ;;

# ------------------------------------------------------------------------------
# sb edit <id|proto port>
# ------------------------------------------------------------------------------
edit)
    id=$(_resolve "$@")
    payload=$(state_get "$id")
    proto=$(echo "$payload" | jq -r '.protocol')

    fn="${PROTO_EDIT[$proto]}"
    if [ -z "$fn" ] || ! declare -F "$fn" >/dev/null 2>&1; then
        err "协议 [${proto}] 未实现 edit 接口"
        exit 1
    fi

    "$fn" "$id" "$payload" || exit 1
    _commit
    ;;

# ------------------------------------------------------------------------------
# sb remove <id|proto port>
# ------------------------------------------------------------------------------
remove)
    id=$(_resolve "$@")
    payload=$(state_get "$id")
    proto=$(echo "$payload" | jq -r '.protocol')
    port=$(echo "$payload"  | jq -r '.port')

    read -rp "⚠️  确认删除 [${id}] ${proto}:${port}？(y/N): " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { info "已取消"; exit 0; }

    state_del "$id"
    ok "[${id}] 已删除"
    _commit
    ;;

# ------------------------------------------------------------------------------
# sb enable <id|proto port>
# ------------------------------------------------------------------------------
enable)
    id=$(_resolve "$@")
    state_enable "$id"
    ok "[${id}] 已启用"
    _commit
    ;;

# ------------------------------------------------------------------------------
# sb disable <id|proto port>
# ------------------------------------------------------------------------------
disable)
    id=$(_resolve "$@")
    state_disable "$id"
    ok "[${id}] 已停用"
    _commit
    ;;

# ------------------------------------------------------------------------------
# sb restart <id|proto port>
# 仅重启单个实例（disable → compile → reload → enable → compile → reload）
# ------------------------------------------------------------------------------
restart)
    id=$(_resolve "$@")
    payload=$(state_get "$id")
    proto=$(echo "$payload" | jq -r '.protocol')
    port=$(echo "$payload"  | jq -r '.port')

    info "[${id}] ${proto}:${port} 正在重启..."
    state_disable "$id"
    compile_all
    service_reload
    sleep 1
    state_enable "$id"
    compile_all
    service_reload
    ok "[${id}] ${proto}:${port} 已重启"
    ;;

# ------------------------------------------------------------------------------
# sb info <id|proto port>
# ------------------------------------------------------------------------------
info)
    id=$(_resolve "$@")
    payload=$(state_get "$id")
    proto=$(echo "$payload" | jq -r '.protocol')

    fn="${PROTO_INFO[$proto]}"
    if [ -z "$fn" ] || ! declare -F "$fn" >/dev/null 2>&1; then
        err "协议 [${proto}] 未实现 info 接口"
        exit 1
    fi

    ipv4=$(get_ipv4)
    "$fn" "$payload" "$ipv4"
    echo ""
    echo "📋 分享链接："
    uri_fn="${PROTO_URI[$proto]}"
    [ -n "$uri_fn" ] && "$uri_fn" "$payload" "$ipv4"
    echo ""
    uri_fn="${PROTO_URI[$proto]}"
    [ -n "$uri_fn" ] && show_qr "$("$uri_fn" "$payload" "$ipv4")"
    ;;

# ------------------------------------------------------------------------------
# sb list
# ------------------------------------------------------------------------------
list)
    echo ""
    printf "%-6s %-8s %-10s %-6s %-8s %-20s\n" \
        "ID" "协议" "状态" "端口" "传输" "创建时间"
    echo "────────────────────────────────────────────────────────────"

    while IFS= read -r id; do
        payload=$(state_get "$id")
        proto=$(echo "$payload"   | jq -r '.protocol')
        port=$(echo "$payload"    | jq -r '.port')
        enabled=$(echo "$payload" | jq -r '.enabled')
        created=$(echo "$payload" | jq -r '.created_at')
        transport="${PROTO_TRANSPORT[$proto]:-?}"

        [ "$enabled" = "true" ] && status="🟢 启用" || status="🔴 停用"

        printf "%-6s %-8s %-10s %-6s %-8s %-20s\n" \
            "$id" "$proto" "$status" "$port" "$transport" "$created"
    done < <(state_list)
    echo ""
    ;;

# ------------------------------------------------------------------------------
# sb uri <id|proto port>
# ------------------------------------------------------------------------------
uri)
    id=$(_resolve "$@")
    payload=$(state_get "$id")
    proto=$(echo "$payload" | jq -r '.protocol')
    ipv4=$(get_ipv4)

    fn="${PROTO_URI[$proto]}"
    [ -z "$fn" ] && { err "协议 [${proto}] 未注册 URI 函数"; exit 1; }

    uri=$("$fn" "$payload" "$ipv4")
    echo ""
    echo "📋 $uri"
    echo ""
    show_qr "$uri"
    ;;

# ------------------------------------------------------------------------------
# sb sub
# ------------------------------------------------------------------------------
sub)
    compile_sub
    echo ""
    cat "$OUTPUT_SUB"
    ;;

# ------------------------------------------------------------------------------
# sb compile
# ------------------------------------------------------------------------------
compile)
    compile_all
    ;;

# ------------------------------------------------------------------------------
# sb reload
# ------------------------------------------------------------------------------
reload)
    compile_all && service_reload
    ;;

# ------------------------------------------------------------------------------
# 服务控制
# ------------------------------------------------------------------------------
start)   service_start   ;;
stop)    service_stop    ;;
status)  service_status  ;;
logs)    service_logs    ;;

# ------------------------------------------------------------------------------
# sb version
# ------------------------------------------------------------------------------
version)
    local ver=""
    [ -f "$SB_BIN" ] && ver=$($SB_BIN version 2>/dev/null | awk '{print $3}')
    echo "sb manager  v2.0"
    echo "sing-box    ${ver:-未安装}"
    ;;

# ------------------------------------------------------------------------------
# sb help
# ------------------------------------------------------------------------------
help|--help|-h)
    echo ""
    echo "用法: sb <命令> [id | 协议 端口]"
    echo ""
    echo "实例管理:"
    printf "  %-28s %s\n" "sb add [协议] [端口]"      "新建实例（自动 compile + reload）"
    printf "  %-28s %s\n" "sb edit <id|协议 端口>"    "编辑实例"
    printf "  %-28s %s\n" "sb remove <id|协议 端口>"  "删除实例"
    printf "  %-28s %s\n" "sb enable <id|协议 端口>"  "启用实例"
    printf "  %-28s %s\n" "sb disable <id|协议 端口>" "停用实例"
    printf "  %-28s %s\n" "sb restart <id|协议 端口>" "重启单个实例"
    printf "  %-28s %s\n" "sb info <id|协议 端口>"    "查看实例详情 + URI"
    printf "  %-28s %s\n" "sb list"                   "列出所有实例"
    printf "  %-28s %s\n" "sb uri <id|协议 端口>"     "打印分享链接 + 二维码"
    echo ""
    echo "服务控制:"
    printf "  %-28s %s\n" "sb start"   "启动 sing-box"
    printf "  %-28s %s\n" "sb stop"    "停止 sing-box"
    printf "  %-28s %s\n" "sb reload"  "重编译 + 热重载"
    printf "  %-28s %s\n" "sb status"  "查看运行状态"
    printf "  %-28s %s\n" "sb logs"    "实时日志"
    echo ""
    echo "订阅 / 配置:"
    printf "  %-28s %s\n" "sb sub"     "生成并打印订阅"
    printf "  %-28s %s\n" "sb compile" "手动重编译（高级）"
    echo ""
    echo "其他:"
    printf "  %-28s %s\n" "sb install" "安装 / 升级 sing-box"
    printf "  %-28s %s\n" "sb version" "版本信息"
    echo ""
    echo "已注册协议:"
    for k in "${PROTO_KEYS[@]}"; do
        printf "  %-10s %s\n" "$k" "${PROTO_MENU[$k]}"
    done
    echo ""
    ;;

*)
    err "未知命令: ${CMD}"
    echo "执行 'sb help' 查看帮助"
    exit 1
    ;;

esac
